# pnpm content-addressable store — 900MB+, not needed on build server
.local/

# node_modules are reinstalled fresh on the EAS build server
node_modules/
**/node_modules/

# iOS build output (2.7GB) and Pods (980MB)
artifacts/tapin-golf/ios/build/
artifacts/tapin-golf/ios/Pods/

# Build outputs from other apps (not needed, keeps source for workspace resolution)
artifacts/api-server/dist/
artifacts/club-portal/dist/
artifacts/club-portal/.next/
artifacts/mockup-sandbox/dist/

# Agent/editor internals
.agents/
.local/state/
.cache/
.upm/

# Large binaries
artifacts/tapin-golf/screenshots/
artifacts/tapin-golf/screenshots.zip

# Keystores
*.jks

# Expo cache
artifacts/tapin-golf/.expo/

# Version control
.git/
