modules = ["nodejs-20", "web", "php-8.2", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_object_storage:2.0.0"]

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 5000

[[ports]]
localPort = 9999
externalPort = 3001

[[ports]]
localPort = 19006
externalPort = 4200

[[ports]]
localPort = 19606
externalPort = 3000

[[ports]]
localPort = 26107
externalPort = 3002

[[ports]]
localPort = 26108
externalPort = 3003

[userenv]

[userenv.development]
STITCH_WEBHOOK_SECRET = "z10qkGUXNQ7bGxy0vIY9dhOwMxSSJczSa1mqp4HLPYjturmBLRErPe+rzUErrUHe"

[userenv.shared]

[deployment]
deploymentTarget = "autoscale"
run = ["pnpm", "--filter", "@workspace/api-server", "run", "start"]
build = ["bash", "-c", "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/club-portal run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[workflows]
